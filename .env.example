# ── Database ──────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/recordchief?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# ── App ───────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-app.vercel.app

# ── Email (for password reset) ────────────────
# Use Gmail App Password or any SMTP provider
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Record Chief <your@gmail.com>

# ── Web Push Notifications ────────────────────
# Generate with: node -e "require('web-push').generateVAPIDKeys()"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@gmail.com
